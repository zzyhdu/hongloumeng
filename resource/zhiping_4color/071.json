      "indent": true,
      "spans": [
        {
          "type": "annotation",
          "source": "戚",
          "position": "",
          "color": "blue",
          "content": "司棋事从鸳鸯误吓得来，是善周全处。方与鸳鸯前后行景不致矛盾。"
        },
        {
          "type": "annotation",
          "source": "戚",
          "position": "",
          "color": "blue",
          "content": "一何精细如此。"
