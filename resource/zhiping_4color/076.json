      "spans": [
        {
          "type": "annotation",
          "source": "戚",
          "position": "",
          "color": "blue",
          "content": "戚总评：诗词清远闲旷，自是慧业才人，何须赘评？须看他众人联"
        },
        {
          "type": "annotation",
          "source": "戚",
          "position": "",
          "color": "blue",
          "content": "句填词时，各人性情，各人意见，叙来恰肖其人；二人联诗时，一番讥"
        },
        {
          "type": "annotation",
          "source": "戚",
          "position": "",
          "color": "blue",
          "content": "评，一番叹赏，叙来更得其神。再看漏永吟残，忽开一洞天福地，字字"
        },
        {
          "type": "annotation",
          "source": "戚",
          "position": "",
          "color": "blue",
          "content": "出人意表。"
        }
      ]
